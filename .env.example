# Copy to .env.local and fill in values from Supabase + Vercel dashboards

# Canonical public URL (auth email links, sitemap, Open Graph)
# Local: omit or use http://localhost:3000
# Production (Vercel): https://city-jam.vercel.app
NEXT_PUBLIC_SITE_URL=https://city-jam.vercel.app

# Supabase (https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Optional alias for NEXT_PUBLIC_SITE_URL
# NEXT_PUBLIC_APP_URL=https://city-jam.vercel.app

# VERCEL_URL is set automatically on Vercel (server-only; not used for client auth emails)
